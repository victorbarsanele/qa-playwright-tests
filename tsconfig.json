{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "lib": ["ES2020", "DOM"],
        "types": ["node", "@playwright/test"],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true
    },
    "include": [
        "playwright.config.ts",
        "tests/**/*.ts",
        "pages/**/*.ts",
        "utils/**/*.ts",
        "requests/**/*.ts"
    ],
    "exclude": ["node_modules"]
}
